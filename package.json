{
  "name": "gerenciador-mods-sims4",
  "version": "1.1.0",
  "description": "Gerenciador de mods para The Sims 4 com interface Fluent 2",
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "electron-builder --win --publish never",
    "test": "jest --config jest.config.js --forceExit",
    "test:watch": "jest --config jest.config.js --watch",
    "postinstall": "git config core.hooksPath .githooks && echo Hook pre-push ativado!"
  },
  "keywords": [
    "sims4",
    "mods",
    "gerenciador",
    "electron",
    "fluent2"
  ],
  "author": "Indefinido",
  "license": "MIT",
  "dependencies": {
    "extract-zip": "^2.0.1"
  },
  "devDependencies": {
    "electron": "^40.8.0",
    "electron-builder": "^26.8.1",
    "jest": "^29.7.0"
  },
  "build": {
    "appId": "com.sims4.modmanager",
    "productName": "TS4 Mod Manager",
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "portable",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "files": [
      "main.js",
      "preload.js",
      "preload-debug.js",
      "src/**/*",
      "assets/**/*",
      "node_modules/**/*"
    ],
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "installerLanguages": [
        "pt_BR"
      ],
      "language": "1046"
    }
  },
  "electron-builder": "^26.8.1"
}
